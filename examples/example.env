# Example .env file with intentional security issues for testing
# All values are placeholders - NOT real secrets

# Application Settings (Safe)
APP_NAME=MyAwesomeApp
APP_ENV=development
DEBUG=true
LOG_LEVEL=debug

# Database Configuration (WARNING: Pattern detected)
DATABASE_URL=postgres://admin:examplepassword@localhost:5432/mydb
DB_PASSWORD=examplepassword123

# AWS Credentials (CRITICAL: Pattern detected)
# Format: AKIA + 16 uppercase alphanumeric chars
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMIK7MDENGbPxRfiCYEXAMPLEKEY

# GitHub Token (CRITICAL: Pattern detected)
# Format: ghp_ + 36 chars
GITHUB_TOKEN=ghp_1234567890abcdefghijklmnopqrstuv

# API Keys (Various Severity)
OPENAI_API_KEY=sk-proj-1234567890abcdefghijklmnop
SENDGRID_API_KEY=SG.12345678.abcdefghij

# Authentication Secrets (CRITICAL)
JWT_SECRET=example-jwt-secret-please-rotate
SESSION_SECRET=example-session-secret

# Safe Configuration
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600
MAX_CONNECTIONS=100
